{
  "name": "@beamflow/plugin-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "SDK for building BeamFlow plugins — node definitions, connectors, and extensions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist *.tsbuildinfo",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@beamflow/shared": "workspace:*",
    "@beamflow/nodes": "workspace:*"
  },
  "devDependencies": {
    "@beamflow/tsconfig": "workspace:*",
    "typescript": "^5.8.0",
    "rimraf": "^6.0.0"
  }
}
