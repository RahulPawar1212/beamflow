{
  "name": "@beamflow/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Headless CLI for the BeamFlow workflow engine (generate / inspect params / run)",
  "type": "module",
  "bin": {
    "beamflow": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist *.tsbuildinfo",
    "test": "vitest run",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@beamflow/shared": "workspace:*",
    "@beamflow/core": "workspace:*",
    "@beamflow/graph": "workspace:*",
    "@beamflow/ir": "workspace:*",
    "@beamflow/beam-generator": "workspace:*",
    "@beamflow/nodes": "workspace:*"
  },
  "devDependencies": {
    "@beamflow/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.8.0",
    "rimraf": "^6.0.0",
    "vitest": "^3.2.0"
  }
}
