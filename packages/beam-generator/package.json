{
  "name": "@beamflow/beam-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Apache Beam code generator for BeamFlow IR pipelines",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist *.tsbuildinfo",
    "test": "vitest run",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@beamflow/shared": "workspace:*",
    "@beamflow/ir": "workspace:*"
  },
  "devDependencies": {
    "@beamflow/tsconfig": "workspace:*",
    "typescript": "^5.8.0",
    "rimraf": "^6.0.0",
    "vitest": "^3.2.0"
  }
}
